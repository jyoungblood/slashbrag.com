---
import "../styles/global.css";
import { Font } from "astro:assets";
import { z } from "astro/zod";
import directory from "../../data.json";

const directorySchema = z.array(
  z
    .object({
      name: z.string().min(1),
      link: z.url(),
      bio: z.string().min(1).max(200),
    })
    .strict(),
);

const lastName = (name: string) => name.slice(name.lastIndexOf(" ") + 1);

const people = directorySchema
  .parse(directory)
  .slice()
  .sort((a, b) => lastName(a.name).localeCompare(lastName(b.name)));
const randomLinks = people.map(({ link }) => link);
---

<html lang="en">
  <head>
    <Font cssVariable="--font-geist-sans" />
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>the /brag directory</title>
  </head>
  <body>
    <main class="min-h-screen">
      <section
        class="mx-auto flex w-full max-w-6xl flex-col gap-8 px-5 py-10 sm:px-8 lg:py-16"
      >
        <header
          class="flex flex-col gap-12 pb-12 md:flex-row md:items-start md:justify-between md:gap-x-12"
        >
          <div class="min-w-0 lg:shrink-0">
            <h1
              class="text-4xl font-bold sm:text-5xl mb-6 uppercase whitespace-nowrap md:whitespace-normal lg:whitespace-nowrap"
            >
              /brag directory
            </h1>
            <a
              id="random-link"
              class="bg-slime-500 hover:bg-black hover:text-white inline-flex items-center gap-2 rounded border border-black md:px-4 px-2 md:py-2 py-1 md:text-sm text-xs font-semibold no-underline transition focus-visible:outline-2 focus-visible:outline-offset-4"
              href="#"
              target="_blank"
              data-links={JSON.stringify(randomLinks)}
            >
              Show me someone cool
            </a>
          </div>
          <div
            class="flex min-w-0 flex-col items-start gap-4 self-start text-neutral-500  md:min-w-72 md:max-w-lg lg:min-w-0"
          >
            <p>
              A /brag page is a living record of useful work. Increase your luck
              surface area by having a non-resume resume always online.
            </p>
            <a
              href="https://github.com/jyoungblood/slashbrag.com"
              target="_blank"
              class="underline underline-offset-3 text-neutral-500 hover:text-slime-700"
              >Add yours here</a
            >
          </div>
        </header>

        <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-3">
          {
            people.map((person) => (
              <article class="flex min-h-32 flex-col justify-between">
                <div>
                  <a
                    href={person.link}
                    target="_blank"
                    class="text-xl font-semibold leading-tight underline underline-offset-4 text-neutral-900 hover:text-slime-700"
                  >
                    {person.name}
                  </a>
                  <div class="mt-2 text-sm leading-6 text-neutral-900">{person.bio}</div>
                </div>
              </article>
            ))
          }
        </div>
        <img
          src="/favicon.svg"
          alt="the /brag directory"
          class="w-18 mx-auto"
        />
        <footer class="text-center text-sm pt-4 text-neutral-500/80">
          Brought to you by the boys at
          <a
            class="underline underline-offset-3 text-neutral-500/80 hover:text-slime-700"
            target="_blank"
            href="https://mostlytechnical.com"
          >
            Mostly Technical
          </a>
          and your friend <a
            class="underline underline-offset-3 text-neutral-500/80 hover:text-slime-700"
            target="_blank"
            href="https://jonathanyoungblood.com"
          >
            Jonathan Youngblood
          </a>
        </footer>
      </section>
    </main>
    <script>
      const randomPersonLink =
        document.querySelector<HTMLAnchorElement>("#random-link");

      randomPersonLink?.addEventListener("click", (event) => {
        const links = JSON.parse(randomPersonLink.dataset.links ?? "[]");
        const randomLink = links[Math.floor(Math.random() * links.length)];

        if (!randomLink) {
          event.preventDefault();
          return;
        }

        randomPersonLink.href = randomLink;
      });
    </script>
  </body>
</html>
